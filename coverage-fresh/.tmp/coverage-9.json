e storage write errors\n      }\n      return { token: newToken, wasInvalid: wasPresent };\n    } catch {\n      const newToken = generateToken();\n      try {\n        localStorage.setItem(STORAGE_KEY, newToken);\n      } catch {\n        // Ignore storage write errors\n      }\n      return { token: newToken, wasInvalid: false };\n    }\n  });\n\n  // useRef guard prevents duplicate toasts in React StrictMode (mount → unmount → remount).\n  const hasShown = useRef(false);\n  useEffect(() => {\n    if (!wasInvalid || hasShown.current) return;\n    hasShown.current = true;\n    showRecoveryToast(\"Your session token was refreshed automatically.\");\n  }, [wasInvalid]);\n\n  return token;\n}\n"],"mappings":"AAAA,SAAS,WAAW,QAAQ,gBAAgB;AAC5C,SAAS,yBAAyB;AAElC,MAAM,cAAc;AAEpB,SAAS,gBAAwB;AAC/B,MAAI,OAAO,WAAW,eAAe,OAAO,YAAY;AACtD,WAAO,OAAO,WAAW;AAAA,EAC3B;AACA,SAAO,KAAK,OAAO,EAAE,SAAS,EAAE,EAAE,UAAU,CAAC,IAAI,KAAK,IAAI,EAAE,SAAS,EAAE;AACzE;AAOA,SAAS,mBAAmB,OAAuC;AACjE,SAAO,OAAO,UAAU,YAAY,MAAM,KAAK,EAAE,UAAU;AAC7D;AAQO,gBAAS,iBAAyB;AACvC,QAAM,CAAC,EAAE,OAAO,WAAW,CAAC,IAAI,SAAS,MAAM;AAC7C,QAAI;AACF,YAAM,SAAS,aAAa,QAAQ,WAAW;AAC/C,UAAI,mBAAmB,MAAM,GAAG;AAC9B,eAAO,EAAE,OAAO,QAAQ,YAAY,MAAM;AAAA,MAC5C;AAEA,YAAM,aAAa,WAAW;AAC9B,YAAM,WAAW,cAAc;AAC/B,UAAI;AACF,qBAAa,QAAQ,aAAa,QAAQ;AAAA,MAC5C,QAAQ;AAAA,MAER;AACA,aAAO,EAAE,OAAO,UAAU,YAAY,WAAW;AAAA,IACnD,QAAQ;AACN,YAAM,WAAW,cAAc;AAC/B,UAAI;AACF,qBAAa,QAAQ,aAAa,QAAQ;AAAA,MAC5C,QAAQ;AAAA,MAER;AACA,aAAO,EAAE,OAAO,UAAU,YAAY,MAAM;AAAA,IAC9C;AAAA,EACF,CAAC;AAGD,QAAM,WAAW,OAAO,KAAK;AAC7B,YAAU,MAAM;AACd,QAAI,CAAC,cAAc,SAAS,QAAS;AACrC,aAAS,UAAU;AACnB,sBAAkB,iDAAiD;AAAA,EACrE,GAAG,CAAC,UAAU,CAAC;AAEf,SAAO;AACT;","names":[]},"_coverageSchema":"1a1c01bbd47fc00a2c39e90264f33305004495a9","hash":"283fc2156443a58d4d64082f9739dd596172aa0a"}}
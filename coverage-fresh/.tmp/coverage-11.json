ning\" ? 8000 : 4000 });\n    })\n    /* istanbul ignore next -- defensive no-op when dynamic sonner import fails (e.g. sonner package removed) */\n    .catch(() => { /* sonner not available */ });\n}\n\n/**\n * Split a single CSV/TSV/Semicolon/Pipe-delimited line into fields,\n * respecting RFC-4180 double-quoted fields (a comma inside quotes is\n * NOT a separator). Accepts comma, semicolon, tab, or pipe as delimiters.\n */\nexport function splitCsvLine(line: string): string[] {\n  const out: string[] = [];\n  let cur = \"\";\n  let q = false;\n  for (let i = 0; i < line.length; i++) {\n    const c = line[i];\n    if (q) {\n      if (c === '\"') {\n        if (line[i + 1] === '\"') { cur += '\"'; i++; } else q = false;\n      } else cur += c;\n    } else if (c === '\"') q = true;\n      else if (c === \",\" || c === \";\" || c === \"\t\" || c === \"|\") { out.push(cur.trim()); cur = \"\"; }\n      else cur += c;\n  }\n  out.push(cur.trim());\n  return out;\n}\n"],"mappings":"AAAA,SAAS,YAA6B;AACtC,SAAS,eAAe;AAEjB,gBAAS,MAAM,QAAsB;AAC1C,SAAO,QAAQ,KAAK,MAAM,CAAC;AAC7B;AAMO,gBAAS,kBACd,SACA,QAA4B,QACtB;AACN,SAAO,QAAQ,EACZ,KAAK,CAAC,EAAE,MAAM,MAAM;AACnB,UAAM,KAAK,UAAU,YAAY,MAAM,UAAU,MAAM;AACvD,OAAG,SAAS,EAAE,UAAU,UAAU,YAAY,MAAO,IAAK,CAAC;AAAA,EAC7D,CAAC,EAEA,MAAM,MAAM;AAAA,EAA6B,CAAC;AAC/C;AAOO,gBAAS,aAAa,MAAwB;AACnD,QAAM,MAAgB,CAAC;AACvB,MAAI,MAAM;AACV,MAAI,IAAI;AACR,WAAS,IAAI,GAAG,IAAI,KAAK,QAAQ,KAAK;AACpC,UAAM,IAAI,KAAK,CAAC;AAChB,QAAI,GAAG;AACL,UAAI,MAAM,KAAK;AACb,YAAI,KAAK,IAAI,CAAC,MAAM,KAAK;AAAE,iBAAO;AAAK;AAAA,QAAK,MAAO,KAAI;AAAA,MACzD,MAAO,QAAO;AAAA,IAChB,WAAW,MAAM,IAAK,KAAI;AAAA,aACf,MAAM,OAAO,MAAM,OAAO,MAAM,OAAO,MAAM,KAAK;AAAE,UAAI,KAAK,IAAI,KAAK,CAAC;AAAG,YAAM;AAAA,IAAI,MACxF,QAAO;AAAA,EAChB;AACA,MAAI,KAAK,IAAI,KAAK,CAAC;AACnB,SAAO;AACT;","names":[]},"_coverageSchema":"1a1c01bbd47fc00a2c39e90264f33305004495a9","hash":"1ecb8c463a503d82b26bc8a5c0f26e7a33dd0420"}}
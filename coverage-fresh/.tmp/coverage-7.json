n Math.max(\n    24,\n    Math.round(12 + cardCount * 1.4 + sectionCount * 5 + Math.max(0, modelCount - 1) * 1.25 + Math.max(0, providerCount - 1) * 3),\n  );\n}\n\nexport function estimatePromptTimeoutSeconds(cardCount: number): number {\n  return Math.max(240, Math.min(900, Math.round(120 + cardCount * 5)));\n}\n\nexport function estimateDocumentTimeoutSeconds(cardCount: number, sectionCount: number): number {\n  return Math.max(\n    300,\n    Math.min(1200, Math.round(150 + cardCount * 5 + Math.max(0, sectionCount - 1) * 45)),\n  );\n}\n"],"mappings":"AAAO,gBAAS,cAAc,SAAyB;AACrD,MAAI,CAAC,OAAO,SAAS,OAAO,EAAG,QAAO;AACtC,QAAM,OAAO,KAAK,IAAI,GAAG,KAAK,MAAM,OAAO,CAAC;AAC5C,QAAM,UAAU,KAAK,MAAM,OAAO,EAAE;AACpC,QAAM,YAAY,OAAO;AACzB,MAAI,WAAW,EAAG,QAAO,GAAG,SAAS;AACrC,SAAO,GAAG,OAAO,KAAK,OAAO,SAAS,EAAE,SAAS,GAAG,GAAG,CAAC;AAC1D;AAEO,gBAAS,yBACd,WACA,YACA,eACQ;AACR,SAAO,KAAK;AAAA,IACV;AAAA,IACA,KAAK,MAAM,IAAI,YAAY,MAAM,KAAK,IAAI,GAAG,aAAa,CAAC,IAAI,OAAO,KAAK,IAAI,GAAG,gBAAgB,CAAC,IAAI,CAAC;AAAA,EAC1G;AACF;AAEO,gBAAS,2BACd,WACA,cACA,YACA,eACQ;AACR,SAAO,KAAK;AAAA,IACV;AAAA,IACA,KAAK,MAAM,KAAK,YAAY,MAAM,eAAe,IAAI,KAAK,IAAI,GAAG,aAAa,CAAC,IAAI,OAAO,KAAK,IAAI,GAAG,gBAAgB,CAAC,IAAI,CAAC;AAAA,EAC9H;AACF;AAEO,gBAAS,6BAA6B,WAA2B;AACtE,SAAO,KAAK,IAAI,KAAK,KAAK,IAAI,KAAK,KAAK,MAAM,MAAM,YAAY,CAAC,CAAC,CAAC;AACrE;AAEO,gBAAS,+BAA+B,WAAmB,cAA8B;AAC9F,SAAO,KAAK;AAAA,IACV;AAAA,IACA,KAAK,IAAI,MAAM,KAAK,MAAM,MAAM,YAAY,IAAI,KAAK,IAAI,GAAG,eAAe,CAAC,IAAI,EAAE,CAAC;AAAA,EACrF;AACF;","names":[]},"_coverageSchema":"1a1c01bbd47fc00a2c39e90264f33305004495a9","hash":"2765eb9b0d0826f0907c6887b340281dd79b8fda"},"/home/ubuntu/genanki/project/src/lib/routing.ts":{"path":"/home/ubuntu/genanki/project/src/lib/routing.ts","statementMap":{"0":{"start":{"line":1,"column":26},"end":{"line":7,"column":1}},"1":{"start":{"line":8,"column":21},"end":{"line":8,"column":24}},"2":{"start":{"line":10,"column":34},"end":{"line":10,"column":43}},"3":{"start":{"line":11,"column":25},"end":{"line":11,"column":81}},"4":
"div\", \"table\", \"thead\",\n  \"tbody\", \"tr\", \"td\", \"th\", \"sup\", \"sub\", \"hr\",\n  // KaTeX emits these MathML tags alongside its HTML output.\n  \"math\", \"semantics\", \"mrow\", \"mi\", \"mo\", \"mn\", \"annotation\",\n];\nconst ALLOWED_ATTR = [\"href\", \"src\", \"class\", \"style\", \"target\", \"rel\", \"aria-hidden\", \"xmlns\", \"encoding\"];\n\nDOMPurify.addHook(\"uponSanitizeAttribute\", (_node, data) => {\n  if (data.attrName.startsWith(\"on\")) data.keepAttr = false;\n  if (data.attrName === \"style\" && /expression\\s*\\(|url\\s*\\(\\s*javascript:/i.test(data.attrValue)) {\n    data.keepAttr = false;\n  }\n});\n\nfunction sanitizeHtml(html: string): string {\n  return DOMPurify.sanitize(html, {\n    ALLOWED_TAGS,\n    ALLOWED_ATTR,\n    ALLOW_DATA_ATTR: false,\n    FORBID_TAGS: [\"script\", \"iframe\", \"object\", \"embed\", \"form\", \"input\", \"button\", \"textarea\", \"select\", \"style\", \"link\", \"meta\", \"base\"],\n  });\n}\n\n// --- Math helpers (extracted for coverage tracking) ---\n\nlet _placeholderCounter = 0;\n\n/** Render math with KaTeX, falling back to error span on failure. */\nfunction renderMath(math: string, displayMode: boolean): string {\n  try {\n    return katex.renderToString(math.trim(), { displayMode, throwOnError: false });\n  } catch {\n    return `<span class=\"text-red-500\">${math}</span>`;\n  }\n}\n\n/** Replace block math (either $$...$$ or \\\\[...\\\\]) with KaTeX HTML and a placeholder key. */\nfunction replaceBlockMath(placeholders: Record<string, string>, math: string): string {\n  const key = `BLOCKMATH${_placeholderCounter++}`;\n  placeholders[key] = renderMath(math, true);\n  return key;\n}\n\n/** Replace inline math (either $...$ or \\\\(...\\\\)) with KaTeX HTML and a placeholder key. */\nfunction replaceInlineMath(placeholders: Record<string, string>, math: string): string {\n  const key = `INLINEMATH${_placeholderCounter++}`;\n  placeholders[key] = renderMath(math, false);\n  return key;\n}\n\n/**\n * Format markdown and math (LaTeX) to HTML for rendering in the web preview UI.\n * Extracts math blocks first so marked doesn't corrupt math symbols (like underscores),\n * escapes HTML for safety/literal tag display, parses with marked, then restores math.\n */\nexport function formatCardText(text: string): string {\n  if (!text) return \"\";\n\n  const placeholders: { [key: string]: string } = {};\n  _placeholderCounter = 0;\n  let processed = text;\n\n  // 1. Extract block math ($$...$$ or \\\\[...\\\\])\n  processed = processed.replace(/\\$\\$([\\s\\S]+?)\\$\\$/g, (_, math) => replaceBlockMath(placeholders, math));\n  processed = processed.replace(/\\\\\\[([\\s\\S]+?)\\\\\\]/g, (_, math) => replaceBlockMath(placeholders, math));\n\n  // 2. Extract inline math ($...$ or \\\\(...\\\\))\n  processed = processed.replace(/\\$(?!\\s)([^$]+?)(?<!\\s)\\$/g, (_, math) => replaceInlineMath(placeholders, math));\n  processed = processed.replace(/\\\\\\(([\\s\\S]+?)\\\\\\)/g, (_, math) => replaceInlineMath(placeholders, math));\n\n  // 3. Compile markdown to HTML\n  let html = \"\";\n  try {\n    html = marked.parse(processed, { breaks: true, gfm: true, async: false });\n  } catch {\n    html = processed;\n  }\n\n  // 4. Restore math placeholders\n  Object.keys(placeholders).forEach((key) => {\n    html = html.split(key).join(placeholders[key]);\n  });\n\n  // 5. Sanitize the final HTML to remove dangerous elements\n  html = sanitizeHtml(html);\n\n  return html;\n}\n\n/**\n * Convert standard math blocks ($$...$$ and $...$) to Anki-native MathJax\n * wrappers (\\\\[...\\\\] and \\\\(...\\\\)) so that math renders correctly in Anki client app.\n */\nexport function formatMathForAnki(text: string): string {\n  if (!text) return \"\";\n  let formatted = text;\n  // Convert $$...$$ to \\\\[...\\\\]\n  formatted = formatted.replace(/\\$\\$([\\s\\S]+?)\\$\\$/g, (_, math) => `\\\\[${math.trim()}\\\\]`);\n  // Convert $...$ to \\\\(...\\\\)\n  formatted = formatted.replace(/\\$(?!\\s)([^$]+?)(?<!\\s)\\$/g, (_, math) => `\\\\(${math.trim()}\\\\)`);\n  return formatted;\n}\n"],"mappings":"AAAA,SAAS,cAAc;AACvB,OAAO,WAAW;AAClB,OAAO,eAAe;AAMtB,MAAM,eAAe;AAAA,EACnB;AAAA,EAAK;AAAA,EAAM;AAAA,EAAU;AAAA,EAAM;AAAA,EAAQ;AAAA,EAAO;AAAA,EAAM;AAAA,EAAM;AAAA,EAAM;AAAA,EAC5D;AAAA,EAAM;AAAA,EAAM;AAAA,EAAM;AAAA,EAAM;AAAA,EAAM;AAAA,EAAM;AAAA,EAAK;AAAA,EAAQ;AAAA,EAAO;AAAA,EAAS;AAAA,EACjE;AAAA,EAAS;AAAA,EAAM;AAAA,EAAM;AAAA,EAAM;AAAA,EAAO;AAAA,EAAO;AAAA;AAAA,EAEzC;AAAA,EAAQ;AAAA,EAAa;AAAA,EAAQ;AAAA,EAAM;AAAA,EAAM;AAAA,EAAM;AACjD;AACA,MAAM,eAAe,CAAC,QAAQ,OAAO,SAAS,SAAS,UAAU,OAAO,eAAe,SAAS,UAAU;AAE1G,UAAU,QAAQ,yBAAyB,CAAC,OAAO,SAAS;AAC1D,MAAI,KAAK,SAAS,WAAW,IAAI,EAAG,MAAK,WAAW;AACpD,MAAI,KAAK,aAAa,WAAW,0CAA0C,KAAK,KAAK,SAAS,GAAG;AAC/F,SAAK,WAAW;AAAA,EAClB;AACF,CAAC;AAED,SAAS,aAAa,MAAsB;AAC1C,SAAO,UAAU,SAAS,MAAM;AAAA,IAC9B;AAAA,IACA;AAAA,IACA,iBAAiB;AAAA,IACjB,aAAa,CAAC,UAAU,UAAU,UAAU,SAAS,QAAQ,SAAS,UAAU,YAAY,UAAU,SAAS,QAAQ,QAAQ,MAAM;AAAA,EACvI,CAAC;AACH;AAIA,IAAI,sBAAsB;AAG1B,SAAS,WAAW,MAAc,aAA8B;AAC9D,MAAI;AACF,WAAO,MAAM,eAAe,KAAK,KAAK,GAAG,EAAE,aAAa,cAAc,MAAM,CAAC;AAAA,EAC/E,QAAQ;AACN,WAAO,8BAA8B,IAAI;AAAA,EAC3C;AACF;AAGA,SAAS,iBAAiB,cAAsC,MAAsB;AACpF,QAAM,MAAM,YAAY,qBAAqB;AAC7C,eAAa,GAAG,IAAI,WAAW,MAAM,IAAI;AACzC,SAAO;AACT;AAGA,SAAS,kBAAkB,cAAsC,MAAsB;AACrF,QAAM,MAAM,aAAa,qBAAqB;AAC9C,eAAa,GAAG,IAAI,WAAW,MAAM,KAAK;AAC1C,SAAO;AACT;AAOO,gBAAS,eAAe,MAAsB;AACnD,MAAI,CAAC,KAAM,QAAO;AAElB,QAAM,eAA0C,CAAC;AACjD,wBAAsB;AACtB,MAAI,YAAY;AAGhB,cAAY,UAAU,QAAQ,uBAAuB,CAAC,GAAG,SAAS,iBAAiB,cAAc,IAAI,CAAC;AACtG,cAAY,UAAU,QAAQ,uBAAuB,CAAC,GAAG,SAAS,iBAAiB,cAAc,IAAI,CAAC;AAGtG,cAAY,UAAU,QAAQ,8BAA8B,CAAC,GAAG,SAAS,kBAAkB,cAAc,IAAI,CAAC;AAC9G,cAAY,UAAU,QAAQ,uBAAuB,CAAC,GAAG,SAAS,kBAAkB,cAAc,IAAI,CAAC;AAGvG,MAAI,OAAO;AACX,MAAI;AACF,WAAO,OAAO,MAAM,WAAW,EAAE,QAAQ,MAAM,KAAK,MAAM,OAAO,MAAM,CAAC;AAAA,EAC1E,QAAQ;AACN,WAAO;AAAA,EACT;AAGA,SAAO,KAAK,YAAY,EAAE,QAAQ,CAAC,QAAQ;AACzC,WAAO,KAAK,MAAM,GAAG,EAAE,KAAK,aAAa,GAAG,CAAC;AAAA,EAC/C,CAAC;AAGD,SAAO,aAAa,IAAI;AAExB,SAAO;AACT;AAMO,gB
# Convex deployment URL (get from Convex dashboard)
# VITE_CONVEX_URL=https://your-project.convex.cloud

# AI Provider API Keys (set one or more)
# GROQ_API_KEY=your_groq_api_key
# CEREBRAS_API_KEY=your_cerebras_api_key
# OPENROUTER_API_KEY=your_openrouter_api_key
# KILO_API_KEY=your_kilo_api_key
# KILO_BASE_URL=https://api.kilo.ai/v1
# KILO_MODEL_IDS=auto-free

# Cloudflare Workers AI (free tier: 10,000 Neurons/day)
# CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
# CLOUDFLARE_API_TOKEN=your_workers_ai_api_token
# Optional: comma-separated model IDs (cheapest-first). Defaults to
# @cf/meta/llama-3.2-3b-instruct, @cf/qwen/qwen3-30b-a3b-fp8, @cf/meta/llama-3.1-8b-instruct-fp8-fast
# CLOUDFLARE_MODEL_IDS=@cf/meta/llama-3.2-3b-instruct,@cf/qwen/qwen3-30b-a3b-fp8

# Vly integrations
# VLY_EMAIL_API_KEY=your_vly_email_api_key
# VLY_APP_NAME=genanki
# VLY_CONVEX_AUTH_ISSUER=https://your-project.convex.site

# OpenRouter metadata (optional)
# OPENROUTER_APP_NAME=genanki
# OPENROUTER_APP_URL=https://your-app-url.com
# OPENROUTER_MODEL=poolside/laguna-xs-2.1:free
